# Public port the FastAPI OCR API listens on.
PORT=8080

# Local vLLM server that serves the GLM-OCR model (started by entrypoint.sh).
VLLM_HOST=127.0.0.1
VLLM_PORT=8000
GLM_OCR_MODEL=glm-ocr
# HF repo (or local path) vLLM loads and serves as GLM_OCR_MODEL.
# VLLM_MODEL_PATH=zai-org/GLM-OCR
# Fraction of GPU memory vLLM may use — GLM-OCR is ~0.9B so this stays low,
# leaving room for the in-process layout model on the same GPU.
# VLLM_GPU_MEMORY_UTILIZATION=0.45

# Device the PP-DocLayoutV3 layout model runs on (shares the GPU with vLLM).
# GLMOCR_LAYOUT_DEVICE=cuda:0

# Limits for the inbound image fetch.
# DOWNLOAD_TIMEOUT_SECONDS=30
# MAX_IMAGE_BYTES=26214400
